# Clinical Evidence Copilot — variables de entorno
# Copia este archivo a .env y rellena los valores.
# NUNCA commitees .env con credenciales reales.

# ---------------------------------------------------------------------------
# LLM: perfil (OpenAI cloud vs llama.cpp local vs sin LLM)
# ---------------------------------------------------------------------------
# COPILOT_LLM_PROFILE=custom   # custom | off | openai | llamacpp (y alias: chatgpt, ollama, …)
#
# --- Perfil ``openai`` (API OpenAI o compatible) ---
# OPENAI_LLM_BASE_URL=https://api.openai.com/v1
# OPENAI_LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
#
# --- Perfil ``llamacpp`` (servidor con API OpenAI-compatible, p. ej. llama-server /v1) ---
# LLAMACPP_LLM_BASE_URL=http://127.0.0.1:8080/v1
# LLAMACPP_LLM_MODEL=nombre-del-modelo-en-el-server
# LLAMACPP_OPENAI_API_KEY=sk-local   # opcional; si vacío se usa un placeholder
#
# ``off`` fuerza COPILOT_QUERY_PLANNER=heuristic (no llama al LLM aunque el .env diga llm).
# Con ``custom`` se usan tal cual ``LLM_BASE_URL``, ``LLM_MODEL`` y ``OPENAI_API_KEY`` de abajo.

# ---------------------------------------------------------------------------
# LLM (OpenAI o compatible — llama.cpp /v1, Ollama, LM Studio, etc.)
# ---------------------------------------------------------------------------
# LLM_BASE_URL debe acabar en /v1 para OpenAI-compatible (llama-server, Ollama, LM Studio).
# Si pones solo host:puerto (p. ej. http://127.0.0.1:11434), el cliente añade /v1 automáticamente.
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=gpt-4o-mini
# Servidor llama.cpp **nativo** (POST /completion), sin /v1 — para scripts o routing local:
# LLAMA_CPP_SERVER_URL=http://127.0.0.1:8080
OPENAI_API_KEY=sk-...      

# ---------------------------------------------------------------------------
# Copiloto API / evaluación
# ---------------------------------------------------------------------------
COPILOT_EVIDENCE_BACKEND=ncbi   # ncbi | stub | epmc | multi
# Recuperación paralela: etapas PubMed + fuentes (NCBI/Europe PMC) vía asyncio.gather (default on).
# COPILOT_PARALLEL_RETRIEVAL=1
# COPILOT_RETRIEVAL_MAX_PARALLEL=8

# Rerank semántico (opcional; pip install -r requirements-semantic.txt)
# COPILOT_SEMANTIC_RERANK=off          # off | embeddings | cross_encoder | full
# Eval / calidad clínica (MedCPT — activar en CI o eval local):
# COPILOT_SEMANTIC_RERANK=cross_encoder
# COPILOT_EMBEDDING_MODEL=ncats/MedCPT-Query-Encoder
# COPILOT_RERANKER_MODEL=ncats/MedCPT-Cross-Encoder
# Bi-encoder general (default si no se especifica MedCPT):
# COPILOT_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# Cross-encoder general:
# COPILOT_RERANKER_MODEL=BAAI/bge-reranker-large
# COPILOT_PUBMED_RETRIEVAL_POOL_MAX=200
# Query PubMed compacta (T2D+drug+CV+edad) + rerank semántico; legacy mega-OR: COPILOT_BROAD_PUBMED_RETRIEVAL=0
# COPILOT_BROAD_PUBMED_RETRIEVAL=1
# Desenlace CV en T1: primary (MACE+CVOT, ~menos ruido) | moderate | strict
# COPILOT_PRIMARY_CV_CLAUSE=primary
# COPILOT_SEMANTIC_PRE_POOL_MAX=300
# COPILOT_SEMANTIC_EMBED_TOP_K=40
# COPILOT_SEMANTIC_PRE_POOL_MAX=200
# COPILOT_SEMANTIC_BATCH_SIZE=64
# COPILOT_SEMANTIC_DEVICE=cuda         # auto si no se especifica
# Planificador PubMed: heurística por defecto (multi-etapa). Legacy en /health.
COPILOT_QUERY_PLANNER=heuristic
# Refinamiento opcional: una etapa extra de retrieval con query generada por LLM (off por defecto).
# COPILOT_PUBMED_LLM_REFINE=1
# COPILOT_PUBMED_PLANNER_MAX_HINT=750   # solo si LLM_REFINE=1
# COPILOT_PUBMED_PLANNER_MAX_TOKENS=384

# Síntesis final: deterministic (default) = MedicalAnswer por reglas; llm = redacción narrativa
# (cohorte/PMIDs/extractos siguen siendo deterministas; sin párrafos fijos de guías en el JSON).
# COPILOT_SYNTHESIS=deterministic
# COPILOT_SYNTHESIS_MAX_TOKENS=1536   # default en código 1536; salida narrativa (dos secciones + PMIDs)
# COPILOT_SYNTHESIS_TIMEOUT=120   # segundos (lectura HTTP); máx. 600. Default 120 (modelos locales lentos).
# COPILOT_SYNTHESIS_TEMPERATURE=0.2
# Si el servidor devuelve «Context size exceeded»: prompt compacto (llamacpp) y, si falla, síntesis en ventanas.
# COPILOT_SYNTHESIS_COMPACT_PROMPT=1   # forzar system prompt corto
# COPILOT_SYNTHESIS_WINDOWED=auto      # off | auto (tras error de contexto) | on (siempre en ventanas)
# COPILOT_SYNTHESIS_PMIDS_PER_WINDOW=1 # PMIDs por llamada en modo ventanas (1–4)
# COPILOT_CLAIM_SLICE=1   # 1 (default): 3 ejes claim (SGLT2/HF, GLP-1/MACE, DOAC/IC bleed); 0|all: todos los ejes

# Vacío = default data/eval/runs.jsonl bajo el repo (app/eval/run_logger.py)
COPILOT_EVAL_LOG_PATH=

# Re-ranking post-PubMed: shingles pregunta↔(título+extracto), sin embeddings (0=off, 1=on).
# COPILOT_EVIDENCE_SHINGLE_RERANK=1

# ---------------------------------------------------------------------------
# PubMed / NCBI E-utilities
# Registra tu email en https://www.ncbi.nlm.nih.gov/account/
# ---------------------------------------------------------------------------
NCBI_EMAIL=tu@email.com
NCBI_API_KEY=                # Opcional; aumenta el rate limit de 3 a 10 req/s

# ---------------------------------------------------------------------------
# Unpaywall (texto completo Open Access por DOI)
# Requiere email válido: https://unpaywall.org/products/api
# ---------------------------------------------------------------------------
UNPAYWALL_EMAIL=tu@email.com

# ---------------------------------------------------------------------------
# Base de datos clínica (Capability A — SqliteClinicalCapability)
# Tras generar datos con Synthea y tu ETL a SQLite, apunta aquí (p. ej. data/clinical/synthea.db).
# Ruta relativa = relativa a la raíz del repo (no al cwd de uvicorn).
CLINICAL_DB_PATH=data/clinical/synthea.db

# ---------------------------------------------------------------------------
# Synthea (perfiles sintéticos de pacientes)
# ---------------------------------------------------------------------------
SYNTHEA_PROFILES_PATH=data/synthea/profiles.json
# Tras run de Synthea con baseDirectory en el copilot (ver docs/SYNTHEA.md)
SYNTHEA_CSV_DIR=data/synthea/output/csv

# ---------------------------------------------------------------------------
# FHIR server (opcional v1)
# ---------------------------------------------------------------------------
FHIR_BASE_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# RAG / Embeddings (opcional v1; por defecto no se usa)
# ---------------------------------------------------------------------------
RAG_EMBEDDING_DEVICE=cpu     # "cuda" si tienes GPU disponible
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50

# ---------------------------------------------------------------------------
# Aplicación
# ---------------------------------------------------------------------------
APP_ENV=development          # development | production
APP_LOG_LEVEL=INFO
